<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           styleClass="auth-background"
           fx:controller="com.university.lms.ui.controller.auth.LoginController">
    <VBox alignment="CENTER" spacing="18" styleClass="auth-card" maxWidth="380">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        <Label text="LibraryOS" styleClass="brand-title"/>
        <Label text="Sign in to continue" styleClass="status-label"/>

        <TextField fx:id="usernameField" promptText="Username or Email"/>
        <PasswordField fx:id="passwordField" promptText="Password"/>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <CheckBox fx:id="rememberMeCheckBox" text="Remember Me"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Hyperlink fx:id="forgotPasswordLink" text="Forgot Password?" onAction="#onForgotPassword"/>
        </HBox>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

        <Button fx:id="loginButton" text="LOGIN" onAction="#onLogin" styleClass="primary-button" maxWidth="Infinity"/>
    </VBox>
</StackPane>
