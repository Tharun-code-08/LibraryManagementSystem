<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           styleClass="auth-background"
           fx:controller="com.university.lms.ui.controller.auth.ForgotPasswordController">
    <VBox alignment="CENTER" spacing="16" styleClass="auth-card" maxWidth="380">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        <Label text="Forgot Password" styleClass="brand-title"/>
        <Label text="Enter your account email and we'll generate reset instructions." wrapText="true" styleClass="status-label"/>

        <TextField fx:id="emailField" promptText="Email"/>

        <Label fx:id="messageLabel" wrapText="true" styleClass="status-label"/>
        <Label fx:id="devTokenLabel" wrapText="true" styleClass="status-label"/>

        <Button fx:id="submitButton" text="SEND RESET INSTRUCTIONS" onAction="#onSubmit" styleClass="primary-button" maxWidth="Infinity"/>
        <Hyperlink text="I have a reset code" onAction="#onHaveResetCode"/>
        <Hyperlink text="Back to Login" onAction="#onBackToLogin"/>
    </VBox>
</StackPane>
