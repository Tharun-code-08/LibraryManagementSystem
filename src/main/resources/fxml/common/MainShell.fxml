<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           styleClass="app-root"
           fx:controller="com.university.lms.ui.controller.common.MainShellController">
    <VBox alignment="CENTER" spacing="24" styleClass="bootstrap-card">
        <padding>
            <Insets top="48" right="64" bottom="48" left="64"/>
        </padding>
        <Label text="LibraryOS" styleClass="brand-title"/>
        <Label fx:id="statusLabel" wrapText="true" styleClass="status-label"/>
        <ToggleButton fx:id="darkModeToggle" text="Toggle Dark Mode" onAction="#onToggleDarkMode"
                      styleClass="primary-button"/>
    </VBox>
</StackPane>
