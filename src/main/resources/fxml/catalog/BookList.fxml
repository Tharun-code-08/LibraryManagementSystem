<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.catalog.BookListController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Book Catalog" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Back to Home" onAction="#onBack"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <TextField fx:id="searchField" promptText="Search by title, ISBN, or author" HBox.hgrow="ALWAYS" onAction="#onSearch"/>
        <ComboBox fx:id="statusFilter" promptText="Status"/>
        <Button text="_Search" mnemonicParsing="true" onAction="#onSearch"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Manage Categories" onAction="#onManageCategories"/>
        <Button text="Bulk Import" onAction="#onBulkImport"/>
        <Button text="+ Add Book" onAction="#onAddBook" styleClass="primary-button"/>
    </HBox>

    <Label fx:id="errorLabel" styleClass="error-label"/>

    <TableView fx:id="bookTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="240"/>
            <TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="140"/>
            <TableColumn fx:id="authorsColumn" text="Author(s)" prefWidth="200"/>
            <TableColumn fx:id="categoryColumn" text="Category" prefWidth="140"/>
            <TableColumn fx:id="copiesColumn" text="Available / Total" prefWidth="140"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="90"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="12">
        <Button fx:id="prevButton" text="◀ Previous" onAction="#onPrevPage"/>
        <Label fx:id="pageLabel"/>
        <Button fx:id="nextButton" text="Next ▶" onAction="#onNextPage"/>
    </HBox>
</VBox>
