<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.catalog.CategoryManagementController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Categories" styleClass="brand-title-small"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Back to Books" onAction="#onBack"/>
        </HBox>
        <TreeView fx:id="categoryTree" VBox.vgrow="ALWAYS"/>
    </VBox>

    <VBox spacing="10" prefWidth="300" styleClass="auth-card">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>
        <Label text="Add / Manage Category" styleClass="status-label"/>
        <TextField fx:id="nameField" promptText="Category name"/>
        <TextArea fx:id="descriptionField" promptText="Description" prefRowCount="3"/>
        <Button text="Add as Root Category" onAction="#onAddRootCategory" maxWidth="Infinity"/>
        <Button text="Add as Sub-Category of Selected" onAction="#onAddSubCategory" maxWidth="Infinity"/>
        <Button fx:id="deleteButton" text="Delete Selected" onAction="#onDelete" maxWidth="Infinity"/>
        <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
    </VBox>
</HBox>
