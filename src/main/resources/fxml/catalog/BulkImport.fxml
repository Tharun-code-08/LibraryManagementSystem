<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="14" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.catalog.BulkImportController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="Bulk Import Books" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Back to Books" onAction="#onBack"/>
    </HBox>

    <Label text="CSV columns: isbn,title,authors,publisher,category,edition,language,cost (authors separated by ;)"
           wrapText="true" styleClass="status-label"/>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="Choose CSV File" onAction="#onChooseFile"/>
        <Label fx:id="selectedFileLabel"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button fx:id="importButton" text="Import" onAction="#onImport" styleClass="primary-button"/>
    </HBox>

    <Label fx:id="summaryLabel" styleClass="status-label"/>
    <ListView fx:id="rejectedRowsList" VBox.vgrow="ALWAYS"/>
</VBox>
