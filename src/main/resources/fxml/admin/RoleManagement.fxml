<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.admin.RoleManagementController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <VBox spacing="10" prefWidth="220">
        <HBox alignment="CENTER_LEFT">
            <Label text="Roles" styleClass="brand-title-small"/>
        </HBox>
        <ListView fx:id="roleList" VBox.vgrow="ALWAYS"/>
    </VBox>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Permission Matrix" styleClass="brand-title-small"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Back to Home" onAction="#onBack"/>
        </HBox>
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <VBox fx:id="permissionCheckBoxContainer" spacing="6">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </VBox>
        </ScrollPane>
        <Button fx:id="saveButton" text="Save Permissions" onAction="#onSave" styleClass="primary-button"/>
        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
    </VBox>
</HBox>
