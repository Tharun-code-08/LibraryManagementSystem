<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.notification.NotificationCenterController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Notifications" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#onRefresh"/>
        <Hyperlink text="Back to Home" onAction="#onBack"/>
    </HBox>

    <Label fx:id="errorLabel" styleClass="error-label"/>

    <ListView fx:id="notificationList" VBox.vgrow="ALWAYS"/>
</VBox>
