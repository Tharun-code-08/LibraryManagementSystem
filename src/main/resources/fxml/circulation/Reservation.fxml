<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.circulation.ReservationController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="Reserve Book" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Back to Home" onAction="#onBack"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="bookSearchField" promptText="Search by title, ISBN, or author" HBox.hgrow="ALWAYS" onAction="#onSearchBooks"/>
        <Button text="Search" onAction="#onSearchBooks"/>
    </HBox>

    <ListView fx:id="searchResultsList" VBox.vgrow="ALWAYS" prefHeight="260"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="memberIdentifierField" promptText="Scan or type Student/Faculty ID" HBox.hgrow="ALWAYS"/>
        <Button fx:id="reserveButton" text="Reserve" onAction="#onReserve" styleClass="primary-button"/>
    </HBox>

    <Label fx:id="resultLabel" wrapText="true" styleClass="status-label"/>
    <Label fx:id="errorLabel" wrapText="true" styleClass="error-label"/>
</VBox>
