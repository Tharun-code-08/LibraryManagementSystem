<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.inventory.SupplierManagementController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Suppliers" styleClass="brand-title-small"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Hyperlink text="Back to Home" onAction="#onBack"/>
        </HBox>
        <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
                <TableColumn fx:id="contactColumn" text="Contact Person" prefWidth="150"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="180"/>
            </columns>
        </TableView>
    </VBox>

    <VBox spacing="8" prefWidth="280" styleClass="auth-card">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>
        <Label text="Add Supplier" styleClass="status-label"/>
        <TextField fx:id="nameField" promptText="Name"/>
        <TextField fx:id="contactField" promptText="Contact Person"/>
        <TextField fx:id="phoneField" promptText="Phone"/>
        <TextField fx:id="emailField" promptText="Email"/>
        <TextField fx:id="addressField" promptText="Address"/>
        <Button text="Save" onAction="#onSave" styleClass="primary-button" maxWidth="Infinity"/>
        <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
    </VBox>
</HBox>
