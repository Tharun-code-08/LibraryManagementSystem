<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true" styleClass="app-root"
            fx:controller="com.university.lms.ui.controller.inventory.PurchaseOrderFormController">
    <VBox spacing="16">
        <padding>
            <Insets top="24" right="32" bottom="24" left="32"/>
        </padding>
        <Label text="New Purchase Order" styleClass="brand-title-small"/>

        <VBox spacing="12" styleClass="auth-card">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Supplier *"/>
            <ComboBox fx:id="supplierCombo" maxWidth="Infinity"/>
            <Label text="Budget Amount"/>
            <TextField fx:id="budgetField" promptText="0.00"/>

            <Label text="Add Line Item" styleClass="status-label"/>
            <HBox spacing="10">
                <TextField fx:id="itemDescriptionField" promptText="Description" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="itemQuantityField" promptText="Qty" prefWidth="70"/>
                <TextField fx:id="itemUnitCostField" promptText="Unit Cost" prefWidth="100"/>
                <Button text="+ Add" onAction="#onAddItem"/>
            </HBox>
            <ListView fx:id="itemsList" prefHeight="150"/>
            <Button text="Remove Selected Item" onAction="#onRemoveSelectedItem"/>
        </VBox>

        <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>

        <HBox spacing="12">
            <Button fx:id="createButton" text="Create Purchase Order" onAction="#onCreate" styleClass="primary-button"/>
            <Button text="Cancel" onAction="#onCancel"/>
        </HBox>
    </VBox>
</ScrollPane>
