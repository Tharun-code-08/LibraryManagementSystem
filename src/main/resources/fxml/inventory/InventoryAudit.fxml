<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.inventory.InventoryAuditController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="Inventory Audit / Shelf Verification" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Back to Home" onAction="#onBack"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="branchCombo" promptText="Branch"/>
        <Button fx:id="startButton" text="Start Audit" onAction="#onStartAudit" styleClass="primary-button"/>
    </HBox>

    <Label fx:id="auditStatusLabel" styleClass="status-label"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="barcodeField" promptText="Scan or type Book Copy Barcode" onAction="#onRecordScan" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="foundStatusCombo" promptText="Found Status"/>
        <TextField fx:id="notesField" promptText="Notes (optional)"/>
        <Button fx:id="scanButton" text="Record Scan" onAction="#onRecordScan"/>
        <Button fx:id="completeButton" text="Complete Audit" onAction="#onCompleteAudit"/>
    </HBox>

    <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>

    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="barcodeColumn" text="Barcode" prefWidth="130"/>
            <TableColumn fx:id="bookTitleColumn" text="Book" prefWidth="220"/>
            <TableColumn fx:id="expectedColumn" text="Expected Status" prefWidth="130"/>
            <TableColumn fx:id="foundColumn" text="Found Status" prefWidth="130"/>
        </columns>
    </TableView>
</VBox>
