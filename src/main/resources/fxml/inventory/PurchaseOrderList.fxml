<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.inventory.PurchaseOrderListController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Purchase Orders" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Back to Home" onAction="#onBack"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ComboBox fx:id="statusFilter" promptText="Status"/>
        <Button text="Filter" onAction="#onFilter"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="+ New Purchase Order" onAction="#onNewPurchaseOrder" styleClass="primary-button"/>
    </HBox>

    <Label fx:id="errorLabel" styleClass="error-label"/>

    <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="supplierColumn" text="Supplier" prefWidth="180"/>
            <TableColumn fx:id="orderedByColumn" text="Ordered By" prefWidth="140"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
            <TableColumn fx:id="totalCostColumn" text="Total Cost" prefWidth="110"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER" spacing="12">
        <Button fx:id="prevButton" text="◀ Previous" onAction="#onPrevPage"/>
        <Label fx:id="pageLabel"/>
        <Button fx:id="nextButton" text="Next ▶" onAction="#onNextPage"/>
    </HBox>
</VBox>
