<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="12" styleClass="app-root"
      fx:controller="com.university.lms.ui.controller.report.ReportController">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Reports" styleClass="brand-title-small"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Back to Home" onAction="#onBack"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ComboBox fx:id="reportTypeCombo" promptText="Report Type"/>
        <TextField fx:id="departmentField" promptText="Department" prefWidth="130"/>
        <TextField fx:id="yearField" promptText="Year" prefWidth="70"/>
        <DatePicker fx:id="fromDatePicker" promptText="From"/>
        <DatePicker fx:id="toDatePicker" promptText="To"/>
        <Button text="Generate" onAction="#onGenerate" styleClass="primary-button"/>
    </HBox>

    <Label fx:id="errorLabel" styleClass="error-label"/>

    <Label fx:id="titleLabel" styleClass="section-title"/>

    <TableView fx:id="reportTable" VBox.vgrow="ALWAYS"/>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button fx:id="exportPdfButton" text="Export PDF" onAction="#onExportPdf"/>
        <Button fx:id="exportExcelButton" text="Export Excel" onAction="#onExportExcel"/>
        <Button fx:id="printButton" text="Print" onAction="#onPrint"/>
    </HBox>
</VBox>
